
@{
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();

    string NavLinkClasses(string controllerName) =>
        currentController == controllerName.ToLowerInvariant()
            ? "text-sm font-semibold text-white relative flex items-center h-full px-1 transition after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-full after:h-[3px] after:bg-accent after:rounded-t-[3px] after:shadow-[0_-2px_10px_rgba(221,183,255,0.6)]"
            : "text-sm font-semibold text-brand/50 relative flex items-center h-full px-1 transition hover:text-brand";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} - Neon Vault" : "Neon Vault")</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700&family=Outfit:wght@@400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@@400;600;700;800&display=swap" rel="stylesheet">

    <!-- Tailwind CSS (Play CDN — swap for a compiled build before shipping to production) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        navy: '#0B1326',
                        'navy-deep': '#060E20',
                        accent: '#DDB7FF',
                        'accent-dark': '#b17be8',
                        brand: '#CFC2D6',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        outfit: ['Outfit', 'sans-serif'],
                        sora: ['Sora', 'sans-serif'],
                    },
                    boxShadow: {
                        'header-glow': '0 8px 32px rgba(221, 183, 255, 0.15)',
                    },
                    transitionTimingFunction: {
                        DEFAULT: 'cubic-bezier(0.4, 0, 0.2, 1)',
                    },
                }
            }
        }
    </script>

    <!-- No Tailwind utility covers ::-webkit-scrollbar, so this stays as plain CSS -->
    <style>
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0B1326; }
        ::-webkit-scrollbar-thumb { background: rgba(30, 41, 59, 0.5); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(207, 194, 214, 0.5); }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body class="bg-navy text-white font-sans overflow-x-hidden min-h-screen flex flex-col">
    <div class="flex flex-col min-h-screen">

        <!-- Top Navigation Bar -->
        <header class="h-16 bg-navy border-b border-slate-800/50 shadow-header-glow flex items-center justify-between px-6 sticky top-0 z-[100]">
            <div class="flex items-center gap-10">
                <a href="/" class="font-sora text-[26px] font-extrabold text-accent uppercase tracking-[1.5px] transition flex items-center gap-2 hover:text-accent-dark hover:[text-shadow:0_0_12px_rgba(221,183,255,0.4)]">
                    <svg class="w-[22px] h-[22px] fill-current" viewBox="0 0 24 24">
                        <path d="M12 2L2 22h20L12 2zm0 3.99L18.49 19H5.51L12 5.99zM11 16h2v2h-2zm0-6h2v4h-2z"/>
                    </svg>
                    <span>Neon Vault</span>
                </a>

                <nav class="hidden md:flex items-center gap-6 h-16">
                    <a href="/Store" class="@NavLinkClasses("Store")">Store</a>
                    <a href="/Library" class="@NavLinkClasses("Library")">Library</a>
                    <a href="/Community" class="@NavLinkClasses("Community")">Community</a>
                    <a href="/Support" class="@NavLinkClasses("Support")">Support</a>
                </nav>
            </div>

            <div class="flex items-center gap-4">
                <!-- Search Bar -->
                <div class="relative w-40 md:w-60">
                    <input type="text" placeholder="Search games..." class="peer w-full bg-white/10 border border-slate-800/50 rounded-full py-2 pl-9 pr-4 text-white text-[13px] outline-none transition focus:border-accent focus:bg-white/15 focus:shadow-[0_0_8px_rgba(221,183,255,0.25)] placeholder:text-brand/50" />
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 fill-brand/50 pointer-events-none transition peer-focus:fill-accent" viewBox="0 0 24 24">
                        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    </svg>
                </div>

                <!-- Shopping Cart -->
                <button type="button" class="bg-transparent border-none cursor-pointer w-[38px] h-[38px] rounded-full flex items-center justify-center text-brand transition hover:bg-white/10 hover:text-accent" title="Shopping Cart">
                    <svg class="w-[18px] h-[18px] fill-current" viewBox="0 0 24 24">
                        <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
                    </svg>
                </button>

                <!-- Profile Picture (move neon_avatar.png into wwwroot/images first) -->
                <div class="relative flex items-center cursor-pointer group" title="User Profile">
                    <img src="/images/neon_avatar.png" alt="Profile" class="w-9 h-9 rounded-full object-cover border-2 border-transparent transition group-hover:border-accent group-hover:shadow-[0_0_10px_rgba(221,183,255,0.5)]" />
                </div>

                <!-- System Settings -->
                <button type="button" class="bg-transparent border-none cursor-pointer w-[38px] h-[38px] rounded-full flex items-center justify-center text-brand transition hover:bg-white/10 hover:text-accent" title="System Settings">
                    <svg class="w-[18px] h-[18px] fill-current" viewBox="0 0 24 24">
                        <path d="M4 4h7v7H4zm0 9h7v7H4zm9-9h7v7h-7zm0 9h7v7h-7z"/>
                    </svg>
                </button>
            </div>
        </header>

        <!-- Page content is injected here by each view -->
        <main class="flex-1 bg-navy">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="bg-navy-deep border-t border-slate-800/50 px-12 pt-12 pb-6 flex flex-col gap-10">
            <div class="flex flex-col md:flex-row md:justify-between gap-10 flex-wrap">

                <!-- Brand Column -->
                <div class="flex flex-col gap-4 max-w-[280px]">
                    <a href="/" class="font-sora text-[22px] font-extrabold text-accent uppercase tracking-[1.5px] transition flex items-center gap-2 hover:text-accent-dark hover:[text-shadow:0_0_12px_rgba(221,183,255,0.4)]">
                        <svg class="w-[22px] h-[22px] fill-current" viewBox="0 0 24 24">
                            <path d="M12 2L2 22h20L12 2zm0 3.99L18.49 19H5.51L12 5.99zM11 16h2v2h-2zm0-6h2v4h-2z"/>
                        </svg>
                        <span>Neon Vault</span>
                    </a>
                    <p class="text-[13px] text-brand/50 leading-[1.7]">Your ultimate destination for premium gaming experiences. Discover, play, and connect with the world's best games.</p>
                    <div class="flex gap-3 mt-1">
                        <!-- Twitter/X -->
                        <a href="#" class="w-9 h-9 rounded-lg bg-white/10 border border-slate-800/50 flex items-center justify-center cursor-pointer text-brand/50 transition no-underline hover:bg-accent/10 hover:border-accent hover:text-accent" title="Twitter">
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.735-8.835L1.254 2.25H8.08l4.213 5.567 5.95-5.567zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        </a>
                        <!-- Discord -->
                        <a href="#" class="w-9 h-9 rounded-lg bg-white/10 border border-slate-800/50 flex items-center justify-center cursor-pointer text-brand/50 transition no-underline hover:bg-accent/10 hover:border-accent hover:text-accent" title="Discord">
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M20.317 4.492c-1.53-.69-3.17-1.2-4.885-1.49a.075.075 0 0 0-.079.036c-.21.369-.444.85-.608 1.23a18.566 18.566 0 0 0-5.487 0 12.36 12.36 0 0 0-.617-1.23A.077.077 0 0 0 8.562 3c-1.714.29-3.354.8-4.885 1.491a.07.07 0 0 0-.032.027C.533 9.093-.32 13.555.099 17.961a.08.08 0 0 0 .031.055 20.03 20.03 0 0 0 5.993 2.98.078.078 0 0 0 .084-.026c.462-.62.874-1.275 1.226-1.963.021-.04.001-.088-.041-.104a13.201 13.201 0 0 1-1.872-.878.075.075 0 0 1-.008-.125c.126-.093.252-.19.372-.287a.075.075 0 0 1 .078-.01c3.927 1.764 8.18 1.764 12.061 0a.075.075 0 0 1 .079.009c.12.098.245.195.372.288a.075.075 0 0 1-.006.125c-.598.344-1.22.635-1.873.877a.075.075 0 0 0-.041.105c.36.687.772 1.341 1.225 1.962a.077.077 0 0 0 .084.028 19.963 19.963 0 0 0 6.002-2.981.076.076 0 0 0 .032-.054c.5-5.094-.838-9.52-3.549-13.442a.06.06 0 0 0-.031-.028zM8.02 15.278c-1.182 0-2.157-1.069-2.157-2.38 0-1.312.956-2.38 2.157-2.38 1.21 0 2.176 1.077 2.157 2.38 0 1.312-.956 2.38-2.157 2.38zm7.975 0c-1.183 0-2.157-1.069-2.157-2.38 0-1.312.955-2.38 2.157-2.38 1.21 0 2.176 1.077 2.157 2.38 0 1.312-.946 2.38-2.157 2.38z"/></svg>
                        </a>
                        <!-- YouTube -->
                        <a href="#" class="w-9 h-9 rounded-lg bg-white/10 border border-slate-800/50 flex items-center justify-center cursor-pointer text-brand/50 transition no-underline hover:bg-accent/10 hover:border-accent hover:text-accent" title="YouTube">
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                        </a>
                        <!-- GitHub -->
                        <a href="#" class="w-9 h-9 rounded-lg bg-white/10 border border-slate-800/50 flex items-center justify-center cursor-pointer text-brand/50 transition no-underline hover:bg-accent/10 hover:border-accent hover:text-accent" title="GitHub">
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                        </a>
                    </div>
                </div>

                <!-- Footer Nav Columns -->
                <div class="flex gap-8 md:gap-14 flex-wrap">
                    <div class="flex flex-col gap-3 min-w-[120px]">
                        <div class="font-outfit text-xs font-bold text-white tracking-[1.5px] uppercase mb-1">Store</div>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Browse Games</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">New Releases</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Special Offers</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Top Sellers</a>
                    </div>
                    <div class="flex flex-col gap-3 min-w-[120px]">
                        <div class="font-outfit text-xs font-bold text-white tracking-[1.5px] uppercase mb-1">Community</div>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Forums</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Events</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Leaderboards</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Guides</a>
                    </div>
                    <div class="flex flex-col gap-3 min-w-[120px]">
                        <div class="font-outfit text-xs font-bold text-white tracking-[1.5px] uppercase mb-1">Support</div>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Help Center</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Contact Us</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Refunds</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">System Status</a>
                    </div>
                    <div class="flex flex-col gap-3 min-w-[120px]">
                        <div class="font-outfit text-xs font-bold text-white tracking-[1.5px] uppercase mb-1">Company</div>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">About Us</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Careers</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Press Kit</a>
                        <a href="#" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Blog</a>
                    </div>
                </div>
            </div>

            <!-- Footer Bottom Bar -->
            <div class="border-t border-slate-800/50 pt-6 flex flex-col md:flex-row md:justify-between items-center flex-wrap gap-3 text-center md:text-left">
                <span class="text-xs text-brand/50">&copy; @DateTime.Now.Year Neon Vault. All rights reserved.</span>
                <div class="flex gap-6">
                    <a href="#" class="text-xs text-brand/50 no-underline transition hover:text-accent">Privacy Policy</a>
                    <a href="#" class="text-xs text-brand/50 no-underline transition hover:text-accent">Terms of Service</a>
                    <a href="#" class="text-xs text-brand/50 no-underline transition hover:text-accent">Cookie Settings</a>
                </div>
            </div>
        </footer>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
