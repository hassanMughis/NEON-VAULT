
@{
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();
    var currentUserName = Context.Session.GetString("CurrentUserName");
    var currentUserProfileImageUrl = Context.Session.GetString("CurrentUserProfileImageUrl");
    var isAdmin = Context.Session.GetString("IsAdmin") == "true";

    string NavLinkClasses(string controllerName, string actionName = "index") =>
        (currentController == controllerName.ToLowerInvariant() && currentAction == actionName.ToLowerInvariant())
            ? "text-sm font-semibold text-white relative flex items-center h-full px-1 transition after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-full after:h-[3px] after:bg-accent after:rounded-t-[3px] after:shadow-[0_-2px_10px_rgba(221,183,255,0.6)]"
            : "text-sm font-semibold text-brand/50 relative flex items-center h-full px-1 transition hover:text-brand";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} - Neon Vault" : "Neon Vault")</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700&family=Outfit:wght@@400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@@400;600;700;800&display=swap" rel="stylesheet">

    <!-- Tailwind CSS (Play CDN — swap for a compiled build before shipping to production) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        navy: '#0B1326',
                        'navy-deep': '#060E20',
                        accent: '#DDB7FF',
                        'accent-dark': '#b17be8',
                        brand: '#CFC2D6',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        outfit: ['Outfit', 'sans-serif'],
                        sora: ['Sora', 'sans-serif'],
                    },
                    boxShadow: {
                        'header-glow': '0 8px 32px rgba(221, 183, 255, 0.15)',
                    },
                    transitionTimingFunction: {
                        DEFAULT: 'cubic-bezier(0.4, 0, 0.2, 1)',
                    },
                }
            }
        }
    </script>

    <!-- No Tailwind utility covers ::-webkit-scrollbar, so this stays as plain CSS -->
    <style>
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0B1326; }
        ::-webkit-scrollbar-thumb { background: rgba(30, 41, 59, 0.5); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(207, 194, 214, 0.5); }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body class="bg-navy text-white font-sans overflow-x-hidden min-h-screen flex flex-col">
    <div class="flex flex-col min-h-screen">

        <!-- Top Navigation Bar -->
        <header class="h-16 bg-navy border-b border-slate-800/50 shadow-header-glow flex items-center justify-between px-6 sticky top-0 z-[100]">
            <div class="flex items-center gap-10">
                <a href="/" class="flex items-center gap-2 transition hover:opacity-80">
                    <img src="/images/neon_vault_logo.png?v=@DateTime.Now.Ticks" alt="Neon Vault" class="h-14 w-auto drop-shadow-[0_0_8px_rgba(221,183,255,0.3)]" />
                </a>

                <nav class="hidden md:flex items-center gap-6 h-16">
                    <a href="/Store" class="@NavLinkClasses("Store", "index")">Store</a>
                    <a href="/Library" class="@NavLinkClasses("Library", "index")">Library</a>
                    <a href="/Community" class="@NavLinkClasses("Community", "index")">Community</a>
                    <a href="/Account/Settings" class="@NavLinkClasses("Account", "settings")">Settings</a>
                    <a href="/Home/Contact" class="@NavLinkClasses("Home", "contact")">Support</a>
                </nav>
            </div>

            <div class="flex items-center gap-4">
                <!-- Search Bar -->
                <form method="get" action="/Store" class="relative w-40 md:w-60">
                    <input type="text" name="search" placeholder="Search games..." class="peer w-full bg-white/10 border border-slate-800/50 rounded-full py-2 pl-9 pr-4 text-white text-[13px] outline-none transition focus:border-accent focus:bg-white/15 focus:shadow-[0_0_8px_rgba(221,183,255,0.25)] placeholder:text-brand/50" />
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 fill-brand/50 pointer-events-none transition peer-focus:fill-accent" viewBox="0 0 24 24">
                        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    </svg>
                </form>

                <!-- Shopping Cart Link with Badge -->
                <a href="/Cart" class="relative bg-transparent border-none cursor-pointer w-[38px] h-[38px] rounded-full flex items-center justify-center text-brand transition hover:bg-white/10 hover:text-accent" title="Shopping Cart">
                    <svg class="w-[18px] h-[18px] fill-current" viewBox="0 0 24 24">
                        <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
                    </svg>
                    <span id="cart-badge" class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full text-[9px] text-white font-bold flex items-center justify-center hidden">0</span>
                </a>

                @if (!string.IsNullOrWhiteSpace(currentUserName))
                {
                    <div class="relative" id="profile-menu-root">
                        <button type="button" id="profile-menu-button" class="flex items-center gap-2 rounded-full border border-slate-800/50 bg-white/5 px-3 py-2 text-sm text-white transition hover:bg-white/10" aria-expanded="false" aria-controls="profile-menu">
                            @if (!string.IsNullOrWhiteSpace(currentUserProfileImageUrl))
                            {
                                <img src="@currentUserProfileImageUrl" alt="Profile" class="h-7 w-7 rounded-full object-cover" />
                            }
                            else
                            {
                                <span class="flex h-7 w-7 items-center justify-center rounded-full bg-accent/20 text-xs font-bold text-accent">@currentUserName.Substring(0, 1).ToUpperInvariant()</span>
                            }
                            <span class="max-w-[100px] truncate">@currentUserName</span>
                            <svg class="h-3.5 w-3.5 fill-current text-brand/60" viewBox="0 0 20 20" aria-hidden="true">
                                <path d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06z" />
                            </svg>
                        </button>

                        <div id="profile-menu" class="absolute right-0 top-[calc(100%+10px)] z-[150] hidden w-48 overflow-hidden rounded-xl border border-slate-800/70 bg-navy-deep/95 py-2 shadow-[0_18px_45px_rgba(0,0,0,0.35)] backdrop-blur">
                            <a href="/Account/Settings" class="block px-4 py-2.5 text-sm text-brand/80 transition hover:bg-white/10 hover:text-accent">Settings</a>
                            @if (isAdmin)
                            {
                                <a href="/Admin/Dashboard" class="block px-4 py-2.5 text-sm text-brand/80 transition hover:bg-white/10 hover:text-accent">Admin</a>
                            }
                            <a href="/Admin/Logout" class="block px-4 py-2.5 text-sm text-brand/80 transition hover:bg-white/10 hover:text-red-400">Logout</a>
                        </div>
                    </div>
                }
                else
                {
                    <a href="/Admin/Login" class="rounded-full border border-slate-800/50 bg-white/5 px-3 py-2 text-sm text-brand/70 transition hover:bg-white/10 hover:text-accent">Login</a>
                }
            </div>
        </header>

        <!-- Toast notification for TempData messages -->
        @if (TempData["Message"] != null)
        {
            <div id="toast" class="fixed top-20 right-6 z-[200] bg-accent/20 border border-accent/40 text-accent text-sm font-semibold px-5 py-3 rounded-xl shadow-lg backdrop-blur-sm animate-[fadeInUp_0.3s_ease-out]">
                @TempData["Message"]
            </div>
        }

        <!-- Page content is injected here by each view -->
        <main class="flex-1 bg-navy">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="bg-navy-deep border-t border-slate-800/50 px-12 pt-12 pb-6 flex flex-col gap-10">
            <div class="flex flex-col md:flex-row md:justify-between gap-10 flex-wrap">

                <!-- Brand Column -->
                <div class="flex flex-col gap-4 max-w-[280px]">
                    <a href="/" class="flex items-center gap-2 transition hover:opacity-80">
                        <img src="/images/neon_vault_logo.png?v=@DateTime.Now.Ticks" alt="Neon Vault" class="h-12 w-auto drop-shadow-[0_0_8px_rgba(221,183,255,0.3)]" />
                    </a>
                    <p class="text-[13px] text-brand/50 leading-[1.7]">Your ultimate destination for premium gaming experiences. Discover, play, and connect with the world's best games.</p>
                </div>

                <!-- Footer Nav Columns -->
                <div class="flex gap-8 md:gap-14 flex-wrap">
                    <div class="flex flex-col gap-3 min-w-[120px]">
                        <div class="font-outfit text-xs font-bold text-white tracking-[1.5px] uppercase mb-1">Store</div>
                        <a href="/Store" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Browse Games</a>
                        <a href="/Store" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">All Products</a>
                    </div>
                    <div class="flex flex-col gap-3 min-w-[120px]">
                        <div class="font-outfit text-xs font-bold text-white tracking-[1.5px] uppercase mb-1">Account</div>
                        <a href="/Cart" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Shopping Cart</a>
                        <a href="/Library" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">My Library</a>
                    </div>
                    @if (isAdmin)
                    {
                        <div class="flex flex-col gap-3 min-w-[120px]">
                            <div class="font-outfit text-xs font-bold text-white tracking-[1.5px] uppercase mb-1">Admin</div>
                            <a href="/Admin/Dashboard" class="text-[13px] text-brand/50 no-underline transition hover:text-accent">Admin Panel</a>
                        </div>
                    }
                </div>
            </div>

            <!-- Footer Bottom Bar -->
            <div class="border-t border-slate-800/50 pt-6 flex flex-col md:flex-row md:justify-between items-center flex-wrap gap-3 text-center md:text-left">
                <span class="text-xs text-brand/50">&copy; @DateTime.Now.Year Neon Vault. All rights reserved.</span>
            </div>
        </footer>
    </div>

    <!-- Cart badge updater + toast auto-dismiss -->
    <script>
        // Update cart badge count
        fetch('/Cart/GetCartCount')
            .then(r => r.json())
            .then(data => {
                const badge = document.getElementById('cart-badge');
                if (data.count > 0) {
                    badge.textContent = data.count;
                    badge.classList.remove('hidden');
                }
            })
            .catch(() => {});

        // Auto-dismiss toast after 3 seconds
        const toast = document.getElementById('toast');
        if (toast) {
            setTimeout(() => { toast.style.opacity = '0'; toast.style.transition = 'opacity 0.5s'; }, 3000);
            setTimeout(() => toast.remove(), 3500);
        }

        const profileMenuRoot = document.getElementById('profile-menu-root');
        const profileMenuButton = document.getElementById('profile-menu-button');
        const profileMenu = document.getElementById('profile-menu');

        if (profileMenuRoot && profileMenuButton && profileMenu) {
            const closeProfileMenu = () => {
                profileMenu.classList.add('hidden');
                profileMenuButton.setAttribute('aria-expanded', 'false');
            };

            profileMenuButton.addEventListener('click', (event) => {
                event.stopPropagation();
                const isOpen = !profileMenu.classList.contains('hidden');
                profileMenu.classList.toggle('hidden', isOpen);
                profileMenuButton.setAttribute('aria-expanded', String(!isOpen));
            });

            document.addEventListener('click', (event) => {
                if (!profileMenuRoot.contains(event.target)) {
                    closeProfileMenu();
                }
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    closeProfileMenu();
                }
            });
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
