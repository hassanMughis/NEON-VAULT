@model List<Neon_vault.Models.Game>
@{ Layout = "_AdminLayout"; ViewData["Title"] = "Manage Games"; }

@section Styles {
<style>
    .table-row:hover { background: rgba(221,183,255,0.025); }
    .table-row { transition: background 0.12s; }
    .game-thumb { transition: transform 0.2s; }
    .table-row:hover .game-thumb { transform: scale(1.05); }
</style>
}

<div class="flex min-h-screen">
    @await Html.PartialAsync("_AdminSidebar", "Games")
    <div class="flex-1 overflow-y-auto bg-[#07101F]">
        <!-- Header -->
        <header class="h-16 border-b border-white/5 flex items-center justify-between px-8 bg-navy-deep/80 backdrop-blur sticky top-0 z-50">
            <div class="flex items-center gap-3">
                <div class="w-1 h-5 rounded-full bg-accent shadow-[0_0_8px_rgba(221,183,255,0.7)]"></div>
                <h1 class="font-sora text-base font-bold text-white">Games</h1>
                <span class="text-xs font-bold text-accent bg-accent/10 border border-accent/20 px-2.5 py-0.5 rounded-full">@Model.Count</span>
            </div>
            <a href="/Admin/CreateGame" class="inline-flex items-center gap-2 bg-accent text-navy-deep font-bold text-xs px-4 py-2 rounded-xl hover:bg-accent-dark hover:text-white transition-all duration-150 shadow-[0_0_16px_rgba(221,183,255,0.2)]">
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                Add Game
            </a>
        </header>

        <div class="p-8">
            @if (TempData["Message"] != null)
            {
                <div class="flex items-center gap-3 mb-6 bg-accent/10 border border-accent/25 text-accent text-sm px-5 py-3 rounded-xl">
                    <svg class="w-4 h-4 fill-current shrink-0" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                    @TempData["Message"]
                </div>
            }

            <div class="bg-navy border border-white/5 rounded-2xl overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-white/5 bg-white/[0.015]">
                                <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-6">Cover</th>
                                <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-4">Title</th>
                                <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-4">Genre</th>
                                <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-4">Price</th>
                                <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-4">Developer</th>
                                <th class="py-3.5 px-4"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var game in Model)
                            {
                                <tr class="table-row border-b border-white/[0.04] last:border-0">
                                    <td class="py-3.5 px-6">
                                        <div class="w-14 h-10 rounded-lg overflow-hidden bg-white/5 border border-white/5 shrink-0">
                                            <img src="@game.CoverImageUrl" alt="@game.Title" class="game-thumb w-full h-full object-cover" />
                                        </div>
                                    </td>
                                    <td class="py-3.5 px-4">
                                        <span class="text-sm text-white font-semibold">@game.Title</span>
                                    </td>
                                    <td class="py-3.5 px-4">
                                        <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-blue-500/10 text-blue-400 border border-blue-500/20 uppercase tracking-wide">@game.Genre</span>
                                    </td>
                                    <td class="py-3.5 px-4">
                                        <span class="text-sm font-bold text-accent font-mono">$@game.Price.ToString("F2")</span>
                                    </td>
                                    <td class="py-3.5 px-4 text-xs text-brand/50">@game.Developer</td>
                                    <td class="py-3.5 px-4">
                                        <div class="flex items-center gap-3">
                                            <a href="/Admin/EditGame/@game.Id" class="inline-flex items-center gap-1 text-xs font-semibold text-accent/70 hover:text-accent transition-colors">
                                                <svg class="w-3 h-3 fill-current" viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                                                Edit
                                            </a>
                                            <span class="text-brand/20">|</span>
                                            <form method="post" action="/Admin/DeleteGame/@game.Id" class="inline" onsubmit="return confirm('Delete @game.Title?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="inline-flex items-center gap-1 text-xs font-semibold text-brand/30 hover:text-red-400 transition-colors">
                                                    <svg class="w-3 h-3 fill-current" viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
