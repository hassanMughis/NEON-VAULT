@model List<Neon_vault.Models.Game>
@{ Layout = "_AdminLayout"; ViewData["Title"] = "Manage Games"; }

<div class="flex min-h-screen">
    @await Html.PartialAsync("_AdminSidebar", "Games")
    <div class="flex-1 overflow-y-auto">
        <header class="h-16 border-b border-slate-800/50 flex items-center justify-between px-6 bg-navy/50 sticky top-0 z-50">
            <h1 class="font-outfit text-lg font-bold text-white">Manage Games (@Model.Count)</h1>
            <a href="/Admin/CreateGame" class="bg-accent text-navy-deep font-bold text-xs px-4 py-2 rounded-lg hover:bg-accent-dark hover:text-white transition">+ Add Game</a>
        </header>
        <div class="p-6">
            @if (TempData["Message"] != null)
            {
                <div class="bg-accent/10 border border-accent/30 text-accent text-sm px-4 py-2 rounded-lg mb-4">@TempData["Message"]</div>
            }
            <div class="bg-navy border border-slate-800/50 rounded-xl overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-800/50 bg-navy-deep">
                            <th class="text-left text-[10px] text-brand/40 uppercase tracking-wider font-semibold py-3 px-4">Image</th>
                            <th class="text-left text-[10px] text-brand/40 uppercase tracking-wider font-semibold py-3 px-4">Title</th>
                            <th class="text-left text-[10px] text-brand/40 uppercase tracking-wider font-semibold py-3 px-4">Genre</th>
                            <th class="text-left text-[10px] text-brand/40 uppercase tracking-wider font-semibold py-3 px-4">Price</th>
                            <th class="text-left text-[10px] text-brand/40 uppercase tracking-wider font-semibold py-3 px-4">Developer</th>
                            <th class="text-left text-[10px] text-brand/40 uppercase tracking-wider font-semibold py-3 px-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var game in Model)
                        {
                            <tr class="border-b border-slate-800/20 hover:bg-white/[0.02] transition">
                                <td class="py-3 px-4"><img src="@game.CoverImageUrl" alt="" class="w-12 h-8 rounded object-cover" /></td>
                                <td class="py-3 px-4 text-xs text-white font-semibold">@game.Title</td>
                                <td class="py-3 px-4 text-xs text-brand/60">@game.Genre</td>
                                <td class="py-3 px-4 text-xs text-accent font-semibold">$@game.Price.ToString("F2")</td>
                                <td class="py-3 px-4 text-xs text-brand/60">@game.Developer</td>
                                <td class="py-3 px-4 flex gap-2">
                                    <a href="/Admin/EditGame/@game.Id" class="text-xs text-accent hover:underline">Edit</a>
                                    <form method="post" action="/Admin/DeleteGame/@game.Id" class="inline" onsubmit="return confirm('Delete @game.Title?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="text-xs text-red-400 hover:underline">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
