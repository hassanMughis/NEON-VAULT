@model List<Neon_vault.Models.Complaint>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Complaints";
}

<div class="flex min-h-screen">
    @await Html.PartialAsync("_AdminSidebar", "Complaints")

    <div class="flex-1 overflow-y-auto">
        <header class="h-16 border-b border-slate-800/50 flex items-center justify-between px-6 bg-navy/50 sticky top-0 z-50">
            <h1 class="font-outfit text-lg font-bold text-white">User Complaints / Feedback</h1>
        </header>

        <div class="p-6">
            @if (!Model.Any())
            {
                <div class="text-center py-20 bg-navy border border-slate-800/50 rounded-xl">
                    <span class="text-4xl mb-4 block">✉️</span>
                    <h2 class="font-outfit text-xl font-bold text-white mb-2">No complaints found</h2>
                    <p class="text-sm text-brand/50">All customer inquiries are currently up-to-date.</p>
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var complaint in Model)
                    {
                        <div class="bg-navy border border-slate-800/50 rounded-xl p-5 hover:border-accent/40 transition">
                            <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                                <div>
                                    <h3 class="font-sora font-semibold text-white text-base">@complaint.Subject</h3>
                                    <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs text-brand/50 mt-1">
                                        <span>From: <strong class="text-white">@complaint.Name</strong></span>
                                        <span>•</span>
                                        <a href="mailto:@complaint.Email" class="text-accent hover:underline">@complaint.Email</a>
                                    </div>
                                </div>
                                <span class="text-[10px] text-brand/40 uppercase tracking-wider bg-white/5 border border-slate-800/50 px-2.5 py-1 rounded-full">
                                    @complaint.SubmittedAt.ToString("MMM dd, yyyy HH:mm")
                                </span>
                            </div>
                            <div class="text-sm text-brand/75 leading-relaxed bg-white/[0.02] border border-slate-800/30 p-4 rounded-lg whitespace-pre-wrap">@complaint.Message</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
