@model string
@{
    var activePage = Model ?? "";
}

<aside class="w-64 bg-navy-deep border-r border-white/5 flex flex-col shrink-0 relative">
    <!-- Subtle left glow -->
    <div class="absolute inset-y-0 right-0 w-px bg-gradient-to-b from-transparent via-accent/20 to-transparent pointer-events-none"></div>

    <!-- Logo / Brand -->
    <div class="h-16 flex items-center px-5 border-b border-white/5 gap-3">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent/30 to-accent/10 border border-accent/30 flex items-center justify-center shrink-0 shadow-[0_0_12px_rgba(221,183,255,0.25)]">
            <svg class="w-4 h-4 fill-accent" viewBox="0 0 24 24"><path d="M12 2L2 22h20L12 2zm0 3.99L18.49 19H5.51L12 5.99z"/></svg>
        </div>
        <div class="flex flex-col leading-none">
            <span class="font-sora text-sm font-extrabold text-white tracking-wide">NEON VAULT</span>
            <span class="text-[9px] text-accent/70 font-semibold tracking-[2px] uppercase mt-0.5">Admin Panel</span>
        </div>
    </div>

    <!-- Nav Items -->
    <nav class="flex-1 py-5 px-3 space-y-0.5">
        <p class="text-[9px] font-bold tracking-[2px] uppercase text-brand/30 px-3 pb-2 pt-1">Main</p>

        <a href="/Admin/Dashboard" class="group flex items-center gap-3 text-sm py-2.5 px-3 rounded-xl transition-all duration-150 @(activePage == "Dashboard" ? "bg-accent/10 text-accent shadow-[0_0_14px_rgba(221,183,255,0.08)] border border-accent/20" : "text-brand/40 hover:bg-white/5 hover:text-white border border-transparent")">
            <span class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 @(activePage == "Dashboard" ? "bg-accent/20" : "bg-white/5 group-hover:bg-white/8")">
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
            </span>
            <span class="font-semibold">Dashboard</span>
            @if (activePage == "Dashboard")
            {
                <span class="ml-auto w-1.5 h-1.5 rounded-full bg-accent shadow-[0_0_6px_rgba(221,183,255,0.8)]"></span>
            }
        </a>

        <a href="/Admin/Orders" class="group flex items-center gap-3 text-sm py-2.5 px-3 rounded-xl transition-all duration-150 @(activePage == "Orders" ? "bg-accent/10 text-accent shadow-[0_0_14px_rgba(221,183,255,0.08)] border border-accent/20" : "text-brand/40 hover:bg-white/5 hover:text-white border border-transparent")">
            <span class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 @(activePage == "Orders" ? "bg-accent/20" : "bg-white/5 group-hover:bg-white/8")">
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0 0 20 5H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>
            </span>
            <span class="font-semibold">Orders</span>
            @if (activePage == "Orders")
            {
                <span class="ml-auto w-1.5 h-1.5 rounded-full bg-accent shadow-[0_0_6px_rgba(221,183,255,0.8)]"></span>
            }
        </a>

        <a href="/Admin/Games" class="group flex items-center gap-3 text-sm py-2.5 px-3 rounded-xl transition-all duration-150 @(activePage == "Games" ? "bg-accent/10 text-accent shadow-[0_0_14px_rgba(221,183,255,0.08)] border border-accent/20" : "text-brand/40 hover:bg-white/5 hover:text-white border border-transparent")">
            <span class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 @(activePage == "Games" ? "bg-accent/20" : "bg-white/5 group-hover:bg-white/8")">
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5S14.67 12 15.5 12s1.5.67 1.5 1.5S16.33 15 15.5 15zm3-3c-.83 0-1.5-.67-1.5-1.5S17.67 10 18.5 10s1.5.67 1.5 1.5S19.33 12 18.5 12z"/></svg>
            </span>
            <span class="font-semibold">Games</span>
            @if (activePage == "Games")
            {
                <span class="ml-auto w-1.5 h-1.5 rounded-full bg-accent shadow-[0_0_6px_rgba(221,183,255,0.8)]"></span>
            }
        </a>

        <a href="/Admin/Users" class="group flex items-center gap-3 text-sm py-2.5 px-3 rounded-xl transition-all duration-150 @(activePage == "Users" ? "bg-accent/10 text-accent shadow-[0_0_14px_rgba(221,183,255,0.08)] border border-accent/20" : "text-brand/40 hover:bg-white/5 hover:text-white border border-transparent")">
            <span class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 @(activePage == "Users" ? "bg-accent/20" : "bg-white/5 group-hover:bg-white/8")">
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
            </span>
            <span class="font-semibold">Users</span>
            @if (activePage == "Users")
            {
                <span class="ml-auto w-1.5 h-1.5 rounded-full bg-accent shadow-[0_0_6px_rgba(221,183,255,0.8)]"></span>
            }
        </a>

        <a href="/Admin/Messages" class="group flex items-center gap-3 text-sm py-2.5 px-3 rounded-xl transition-all duration-150 @(activePage == "Messages" ? "bg-accent/10 text-accent shadow-[0_0_14px_rgba(221,183,255,0.08)] border border-accent/20" : "text-brand/40 hover:bg-white/5 hover:text-white border border-transparent")">
            <span class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 @(activePage == "Messages" ? "bg-accent/20" : "bg-white/5 group-hover:bg-white/8")">
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            </span>
            <span class="font-semibold">Messages</span>
            @if (activePage == "Messages")
            {
                <span class="ml-auto w-1.5 h-1.5 rounded-full bg-accent shadow-[0_0_6px_rgba(221,183,255,0.8)]"></span>
            }
        </a>
    </nav>

    <!-- Bottom: Back to site + Logout -->
    <div class="border-t border-white/5 p-3 space-y-1">
        <a href="/Store" class="flex items-center gap-3 text-sm py-2.5 px-3 rounded-xl text-brand/40 hover:bg-white/5 hover:text-white transition-all duration-150 border border-transparent">
            <span class="w-7 h-7 rounded-lg bg-white/5 flex items-center justify-center shrink-0">
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
            </span>
            <span class="font-semibold">Back to Store</span>
        </a>
        <a href="/Admin/Logout" class="flex items-center gap-3 text-sm py-2.5 px-3 rounded-xl text-brand/40 hover:bg-red-500/10 hover:text-red-400 transition-all duration-150 border border-transparent">
            <span class="w-7 h-7 rounded-lg bg-white/5 flex items-center justify-center shrink-0">
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
            </span>
            <span class="font-semibold">Logout</span>
        </a>
    </div>
</aside>
