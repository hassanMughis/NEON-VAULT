@model Neon_vault.Models.Order
@{ Layout = "_AdminLayout"; ViewData["Title"] = "Order Details"; }

<div class="flex min-h-screen">
    @await Html.PartialAsync("_AdminSidebar", "Orders")
    <div class="flex-1 overflow-y-auto bg-[#07101F]">
        <!-- Header -->
        <header class="h-16 border-b border-white/5 flex items-center gap-4 px-8 bg-navy-deep/80 backdrop-blur sticky top-0 z-50">
            <a href="/Admin/Orders" class="w-8 h-8 rounded-xl bg-white/5 border border-white/5 flex items-center justify-center text-brand/50 hover:text-accent hover:border-accent/30 transition-all duration-150">
                <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
            </a>
            <div class="w-px h-5 bg-white/10"></div>
            <div class="flex items-center gap-3">
                <div class="w-1 h-5 rounded-full bg-accent shadow-[0_0_8px_rgba(221,183,255,0.7)]"></div>
                <h1 class="font-sora text-base font-bold text-white">Order</h1>
                <span class="font-mono text-xs text-accent bg-accent/10 border border-accent/20 px-2.5 py-0.5 rounded-lg">#@Model.Id.ToString().Substring(0, 8).ToUpper()</span>
            </div>
        </header>

        <div class="p-8 max-w-3xl space-y-6">
            <!-- Order Meta -->
            <div class="bg-navy border border-white/5 rounded-2xl p-6">
                <h2 class="text-xs font-bold text-brand/30 uppercase tracking-[1.5px] mb-5">Order Information</h2>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
                    <div class="bg-white/[0.03] rounded-xl p-4">
                        <p class="text-[10px] text-brand/30 uppercase tracking-wider font-bold mb-1.5">Customer</p>
                        <p class="text-sm text-white font-semibold">@Model.CustomerName</p>
                    </div>
                    <div class="bg-white/[0.03] rounded-xl p-4">
                        <p class="text-[10px] text-brand/30 uppercase tracking-wider font-bold mb-1.5">Email</p>
                        <p class="text-xs text-brand/60 font-mono break-all">@Model.CustomerEmail</p>
                    </div>
                    <div class="bg-white/[0.03] rounded-xl p-4">
                        <p class="text-[10px] text-brand/30 uppercase tracking-wider font-bold mb-1.5">Date</p>
                        <p class="text-xs text-white font-mono">@Model.OrderDate.ToString("MMM dd, yyyy")<br /><span class="text-brand/40">@Model.OrderDate.ToString("HH:mm")</span></p>
                    </div>
                    <div class="bg-white/[0.03] rounded-xl p-4">
                        <p class="text-[10px] text-brand/30 uppercase tracking-wider font-bold mb-1.5">Status</p>
                        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold px-2.5 py-1 rounded-full bg-green-400/10 text-green-400 border border-green-400/20 uppercase tracking-wide">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                            @Model.PaymentStatus
                        </span>
                    </div>
                </div>
            </div>

            <!-- Order Items -->
            <div class="bg-navy border border-white/5 rounded-2xl overflow-hidden">
                <div class="px-6 py-4 border-b border-white/5">
                    <h2 class="text-xs font-bold text-brand/30 uppercase tracking-[1.5px]">Order Items</h2>
                </div>
                <div class="divide-y divide-white/[0.04]">
                    @foreach (var item in Model.OrderItems)
                    {
                        <div class="flex items-center gap-4 px-6 py-4">
                            <div class="w-16 h-11 rounded-xl overflow-hidden bg-white/5 border border-white/5 shrink-0">
                                <img src="@item.Game?.CoverImageUrl" alt="@item.Game?.Title" class="w-full h-full object-cover" />
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm text-white font-semibold truncate">@item.Game?.Title</p>
                                <p class="text-xs text-brand/40 mt-0.5">@item.Game?.Genre</p>
                            </div>
                            <span class="text-sm font-bold text-accent font-mono shrink-0">$@item.PriceAtPurchase.ToString("F2")</span>
                        </div>
                    }
                </div>
                <!-- Total -->
                <div class="px-6 py-4 border-t border-white/5 bg-white/[0.02] flex items-center justify-between">
                    <span class="text-sm font-semibold text-brand/60">Order Total</span>
                    <span class="font-sora text-2xl font-extrabold text-accent">$@Model.TotalAmount.ToString("F2")</span>
                </div>
            </div>
        </div>
    </div>
</div>
