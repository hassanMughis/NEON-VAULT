@model List<Neon_vault.Models.Order>
@{ Layout = "_AdminLayout"; ViewData["Title"] = "All Orders"; }

@section Styles {
<style>
    .status-paid { background: rgba(74,222,128,0.1); color: #4ade80; border-color: rgba(74,222,128,0.25); }
    .table-row:hover { background: rgba(221,183,255,0.025); }
    .table-row { transition: background 0.12s; }
</style>
}

<div class="flex min-h-screen">
    @await Html.PartialAsync("_AdminSidebar", "Orders")
    <div class="flex-1 overflow-y-auto bg-[#07101F]">
        <!-- Header -->
        <header class="h-16 border-b border-white/5 flex items-center justify-between px-8 bg-navy-deep/80 backdrop-blur sticky top-0 z-50">
            <div class="flex items-center gap-3">
                <div class="w-1 h-5 rounded-full bg-accent shadow-[0_0_8px_rgba(221,183,255,0.7)]"></div>
                <h1 class="font-sora text-base font-bold text-white">Orders</h1>
                <span class="text-xs font-bold text-accent bg-accent/10 border border-accent/20 px-2.5 py-0.5 rounded-full">@Model.Count</span>
            </div>
            <a href="/Admin/Logout" class="text-xs text-brand/30 hover:text-red-400 transition-colors flex items-center gap-1.5">
                <svg class="w-3 h-3 fill-current" viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                Logout
            </a>
        </header>

        <div class="p-8">
            @if (!Model.Any())
            {
                <div class="flex flex-col items-center justify-center py-24 gap-4">
                    <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/5 flex items-center justify-center">
                        <svg class="w-8 h-8 fill-brand/20" viewBox="0 0 24 24"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0 0 20 5H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>
                    </div>
                    <p class="text-sm text-brand/30 font-semibold">No orders have been placed yet.</p>
                </div>
            }
            else
            {
                <div class="bg-navy border border-white/5 rounded-2xl overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="border-b border-white/5 bg-white/[0.015]">
                                    <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-6">Order ID</th>
                                    <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-4">Customer</th>
                                    <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-4">Email</th>
                                    <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-4">Items</th>
                                    <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-4">Total</th>
                                    <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-4">Date</th>
                                    <th class="text-left text-[10px] text-brand/30 uppercase tracking-[1.5px] font-bold py-3.5 px-4">Status</th>
                                    <th class="py-3.5 px-4"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model)
                                {
                                    <tr class="table-row border-b border-white/[0.04] last:border-0">
                                        <td class="py-4 px-6">
                                            <span class="font-mono text-xs text-accent bg-accent/10 px-2 py-0.5 rounded-md">#@order.Id.ToString().Substring(0, 8).ToUpper()</span>
                                        </td>
                                        <td class="py-4 px-4 text-sm text-white font-semibold">@order.CustomerName</td>
                                        <td class="py-4 px-4 text-xs text-brand/50">@order.CustomerEmail</td>
                                        <td class="py-4 px-4">
                                            <span class="text-xs text-brand/50 bg-white/5 px-2.5 py-1 rounded-lg font-semibold">@order.OrderItems.Count</span>
                                        </td>
                                        <td class="py-4 px-4 text-sm font-bold text-white">$@order.TotalAmount.ToString("F2")</td>
                                        <td class="py-4 px-4 text-xs text-brand/40 font-mono">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                        <td class="py-4 px-4">
                                            <span class="status-paid text-[10px] font-bold px-3 py-1 rounded-full border tracking-wide uppercase">@order.PaymentStatus</span>
                                        </td>
                                        <td class="py-4 px-4">
                                            <a href="/Admin/OrderDetails/@order.Id" class="inline-flex items-center gap-1 text-xs font-semibold text-accent/70 hover:text-accent transition-colors whitespace-nowrap">
                                                Receipt
                                                <svg class="w-3 h-3 fill-current" viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
