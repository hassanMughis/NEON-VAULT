@model Neon_vault.Models.Game
@{ Layout = "_AdminLayout"; ViewData["Title"] = "Edit Game"; }

<div class="flex min-h-screen">
    @await Html.PartialAsync("_AdminSidebar", "Games")
    <div class="flex-1 overflow-y-auto">
        <header class="h-16 border-b border-slate-800/50 flex items-center px-6 bg-navy/50 sticky top-0 z-50">
            <a href="/Admin/Games" class="text-brand/40 hover:text-accent transition mr-3">← Back</a>
            <h1 class="font-outfit text-lg font-bold text-white">Edit: @Model.Title</h1>
        </header>
        <div class="p-6 max-w-2xl">
            <form method="post" action="/Admin/EditGame/@Model.Id" class="bg-navy border border-slate-800/50 rounded-xl p-6 space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id" />
                <div>
                    <label class="text-xs text-brand/40 uppercase tracking-wider block mb-1.5">Title</label>
                    <input type="text" name="Title" value="@Model.Title" required class="w-full bg-white/5 border border-slate-800/50 rounded-lg py-2.5 px-4 text-white text-sm outline-none focus:border-accent transition" />
                </div>
                <div>
                    <label class="text-xs text-brand/40 uppercase tracking-wider block mb-1.5">Description</label>
                    <textarea name="Description" rows="4" class="w-full bg-white/5 border border-slate-800/50 rounded-lg py-2.5 px-4 text-white text-sm outline-none focus:border-accent transition resize-none">@Model.Description</textarea>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-xs text-brand/40 uppercase tracking-wider block mb-1.5">Price ($)</label>
                        <input type="number" step="0.01" name="Price" value="@Model.Price" required class="w-full bg-white/5 border border-slate-800/50 rounded-lg py-2.5 px-4 text-white text-sm outline-none focus:border-accent transition" />
                    </div>
                    <div>
                        <label class="text-xs text-brand/40 uppercase tracking-wider block mb-1.5">Genre</label>
                        <input type="text" name="Genre" value="@Model.Genre" required class="w-full bg-white/5 border border-slate-800/50 rounded-lg py-2.5 px-4 text-white text-sm outline-none focus:border-accent transition" />
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-xs text-brand/40 uppercase tracking-wider block mb-1.5">Developer</label>
                        <input type="text" name="Developer" value="@Model.Developer" required class="w-full bg-white/5 border border-slate-800/50 rounded-lg py-2.5 px-4 text-white text-sm outline-none focus:border-accent transition" />
                    </div>
                    <div>
                        <label class="text-xs text-brand/40 uppercase tracking-wider block mb-1.5">Release Date</label>
                        <input type="date" name="ReleaseDate" value="@Model.ReleaseDate.ToString("yyyy-MM-dd")" class="w-full bg-white/5 border border-slate-800/50 rounded-lg py-2.5 px-4 text-white text-sm outline-none focus:border-accent transition" />
                    </div>
                </div>
                <div>
                    <label class="text-xs text-brand/40 uppercase tracking-wider block mb-1.5">Cover Image URL</label>
                    <input type="text" name="CoverImageUrl" value="@Model.CoverImageUrl" class="w-full bg-white/5 border border-slate-800/50 rounded-lg py-2.5 px-4 text-white text-sm outline-none focus:border-accent transition" />
                </div>
                <button type="submit" class="w-full bg-accent text-navy-deep font-bold text-sm py-3 rounded-lg hover:bg-accent-dark hover:text-white transition-all">Save Changes</button>
            </form>
        </div>
    </div>
</div>
