@model Neon_vault.Models.Game
@{ Layout = "_AdminLayout"; ViewData["Title"] = "Add New Game"; }

@section Styles {
<style>
    .form-input {
        width: 100%; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
        border-radius: 12px; padding: 11px 16px; color: #fff; font-size: 0.875rem;
        outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    }
    .form-input:focus { border-color: rgba(221,183,255,0.5); box-shadow: 0 0 0 3px rgba(221,183,255,0.08); }
    .form-input::placeholder { color: rgba(207,194,214,0.3); }
    select.form-input option { background: #0B1326; }
</style>
}

<div class="flex min-h-screen">
    @await Html.PartialAsync("_AdminSidebar", "Games")
    <div class="flex-1 overflow-y-auto bg-[#07101F]">
        <!-- Header -->
        <header class="h-16 border-b border-white/5 flex items-center gap-4 px-8 bg-navy-deep/80 backdrop-blur sticky top-0 z-50">
            <a href="/Admin/Games" class="w-8 h-8 rounded-xl bg-white/5 border border-white/5 flex items-center justify-center text-brand/50 hover:text-accent hover:border-accent/30 transition-all duration-150">
                <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
            </a>
            <div class="w-px h-5 bg-white/10"></div>
            <div class="w-1 h-5 rounded-full bg-accent shadow-[0_0_8px_rgba(221,183,255,0.7)]"></div>
            <h1 class="font-sora text-base font-bold text-white">Add New Game</h1>
        </header>

        <div class="p-8 max-w-2xl">
            <form method="post" action="/Admin/CreateGame" enctype="multipart/form-data" class="space-y-5">
                @Html.AntiForgeryToken()

                <!-- Title -->
                <div class="bg-navy border border-white/5 rounded-2xl p-5">
                    <h2 class="text-[10px] font-bold text-brand/30 uppercase tracking-[1.5px] mb-4">Game Info</h2>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-xs font-semibold text-brand/50 mb-2">Title *</label>
                            <input type="text" name="Title" value="@Model.Title" required class="form-input" placeholder="e.g. Cyberpunk 2077" />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-brand/50 mb-2">Description</label>
                            <textarea name="Description" rows="4" class="form-input resize-none" placeholder="Write a brief description...">@Model.Description</textarea>
                        </div>
                    </div>
                </div>

                <!-- Pricing & Genre -->
                <div class="bg-navy border border-white/5 rounded-2xl p-5">
                    <h2 class="text-[10px] font-bold text-brand/30 uppercase tracking-[1.5px] mb-4">Details</h2>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-semibold text-brand/50 mb-2">Price ($) *</label>
                            <input type="number" step="0.01" name="Price" value="@Model.Price" required class="form-input" placeholder="0.00" />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-brand/50 mb-2">Genre *</label>
                            <input type="text" name="Genre" value="@Model.Genre" required class="form-input" placeholder="e.g. Action RPG" />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-brand/50 mb-2">Developer *</label>
                            <input type="text" name="Developer" value="@Model.Developer" required class="form-input" placeholder="e.g. CD Projekt Red" />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-brand/50 mb-2">Release Date</label>
                            <input type="date" name="ReleaseDate" value="@Model.ReleaseDate.ToString("yyyy-MM-dd")" class="form-input" />
                        </div>
                    </div>
                    <div class="mt-4">
                        <label class="block text-xs font-semibold text-brand/50 mb-2">Category</label>
                        <select name="Category" class="form-input">
                            <option value="Game" selected>Game</option>
                            <option value="Hardware">Hardware</option>
                        </select>
                    </div>
                </div>

                <!-- Cover Image -->
                <div class="bg-navy border border-white/5 rounded-2xl p-5">
                    <h2 class="text-[10px] font-bold text-brand/30 uppercase tracking-[1.5px] mb-4">Cover Image</h2>
                    <div id="drop-zone" class="border-2 border-dashed border-white/10 rounded-xl p-8 text-center hover:border-accent/30 transition-colors cursor-pointer relative">
                        <input type="file" name="CoverImage" accept="image/*" id="cover-image-input" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                        <div id="drop-placeholder">
                            <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center mx-auto mb-3">
                                <svg class="w-5 h-5 fill-brand/30" viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                            </div>
                            <p class="text-sm text-brand/50 font-semibold">Drop image here or click to browse</p>
                            <p class="text-xs text-brand/30 mt-1">PNG, JPG, WEBP supported</p>
                        </div>
                        <div id="image-preview" class="hidden">
                            <img id="preview-img" src="" alt="Preview" class="h-36 w-auto object-cover rounded-xl mx-auto border border-white/10" />
                            <p class="text-xs text-brand/40 mt-2">Click to change image</p>
                        </div>
                    </div>
                </div>

                <button type="submit" class="w-full bg-accent text-navy-deep font-bold text-sm py-3.5 rounded-xl hover:bg-accent-dark hover:text-white transition-all duration-150 shadow-[0_0_20px_rgba(221,183,255,0.2)] hover:shadow-[0_0_28px_rgba(221,183,255,0.3)]">
                    Create Game
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('cover-image-input').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(ev) {
                document.getElementById('preview-img').src = ev.target.result;
                document.getElementById('drop-placeholder').classList.add('hidden');
                document.getElementById('image-preview').classList.remove('hidden');
            };
            reader.readAsDataURL(file);
        }
    });
</script>
}
