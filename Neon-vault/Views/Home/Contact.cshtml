@section Scripts {
<script>
    async function handleContactSubmit(e) {
        e.preventDefault();

        const btn = document.getElementById('send-btn');
        const successEl = document.getElementById('form-success');
        const errorEl = document.getElementById('form-error');

        // Reset state
        successEl.classList.add('hidden'); successEl.classList.remove('flex');
        errorEl.classList.add('hidden'); errorEl.classList.remove('flex');

        // Loading state
        btn.disabled = true;
        btn.innerHTML = '<svg class="w-4 h-4 fill-current animate-spin" viewBox="0 0 24 24"><path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/></svg> Sending...';

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const body = new URLSearchParams({
            __RequestVerificationToken: token,
            name:    document.getElementById('cf-name').value,
            email:   document.getElementById('cf-email').value,
            subject: document.getElementById('cf-subject').value,
            message: document.getElementById('cf-message').value,
        });

        try {
            const res = await fetch('/Home/Contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body.toString()
            });

            if (res.ok) {
                btn.classList.add('hidden');
                successEl.classList.remove('hidden');
                successEl.classList.add('flex');
                document.getElementById('contact-form').reset();
            } else {
                throw new Error('Server error');
            }
        } catch {
            btn.disabled = false;
            btn.innerHTML = '<svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg> Send Message';
            errorEl.classList.remove('hidden');
            errorEl.classList.add('flex');
        }
    }
</script>
}
