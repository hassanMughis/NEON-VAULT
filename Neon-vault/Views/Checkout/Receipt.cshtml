@model Neon_vault.Models.Order
@{
    ViewData["Title"] = "Order Receipt";
}

<div class="max-w-2xl mx-auto px-6 py-8">
    <div class="bg-navy-deep border border-slate-800/50 rounded-2xl p-8 text-center">
        <!-- Success Icon -->
        <div class="w-16 h-16 bg-green-500/20 border border-green-500/40 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-400 fill-current" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
        </div>

        <h1 class="font-sora text-2xl font-extrabold text-white mb-2">Purchase Complete!</h1>
        <p class="text-sm text-brand/50 mb-6">Thank you for your purchase, @Model.CustomerName.</p>
    </div>

    <!-- Receipt Card -->
    <div class="bg-navy-deep border border-slate-800/50 rounded-2xl p-6 mt-6">
        <div class="flex items-center justify-between mb-5">
            <h2 class="font-outfit text-lg font-bold text-white">🧾 Order Receipt</h2>
            <span class="text-xs text-brand/40 font-mono">#@Model.Id.ToString().Substring(0, 8).ToUpper()</span>
        </div>

        <!-- Order Meta -->
        <div class="grid grid-cols-2 gap-4 text-sm mb-5 pb-5 border-b border-slate-800/50">
            <div><span class="text-brand/40 text-xs uppercase tracking-wider">Customer</span><p class="text-white mt-0.5">@Model.CustomerName</p></div>
            <div><span class="text-brand/40 text-xs uppercase tracking-wider">Email</span><p class="text-white mt-0.5">@Model.CustomerEmail</p></div>
            <div><span class="text-brand/40 text-xs uppercase tracking-wider">Order Date</span><p class="text-white mt-0.5">@Model.OrderDate.ToString("MMM dd, yyyy HH:mm")</p></div>
            <div><span class="text-brand/40 text-xs uppercase tracking-wider">Status</span><p class="text-green-400 mt-0.5 font-semibold">@Model.PaymentStatus</p></div>
        </div>

        <!-- Items -->
        <div class="space-y-3 mb-5">
            @foreach (var item in Model.OrderItems)
            {
                <div class="flex items-center gap-4">
                    <img src="@item.Game?.CoverImageUrl" alt="@item.Game?.Title" class="w-12 h-8 rounded object-cover" />
                    <span class="flex-1 text-sm text-white">@item.Game?.Title</span>
                    <span class="text-sm font-bold text-accent">$@item.PriceAtPurchase.ToString("F2")</span>
                </div>
            }
        </div>

        <!-- Total -->
        <div class="border-t border-slate-800/50 pt-4 flex justify-between items-center">
            <span class="text-sm font-semibold text-white">Total Paid</span>
            <span class="text-xl font-extrabold text-accent font-sora">$@Model.TotalAmount.ToString("F2")</span>
        </div>
    </div>

    <!-- Actions -->
    <div class="flex gap-3 mt-6">
        <a href="/Library" class="flex-1 bg-accent text-navy-deep font-bold text-sm py-3 rounded-lg hover:bg-accent-dark hover:text-white transition-all text-center">Go to Library</a>
        <a href="/Store" class="flex-1 bg-white/10 border border-white/20 text-white font-semibold text-sm py-3 rounded-lg hover:bg-white/20 transition text-center">Continue Shopping</a>
    </div>
</div>
