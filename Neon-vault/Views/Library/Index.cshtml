@model List<Neon_vault.Models.LibraryItem>
@{
    ViewData["Title"] = "My Library";
}

<div class="max-w-7xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="font-sora text-2xl font-extrabold text-white">My Library</h1>
            <p class="text-sm text-brand/50 mt-1">@Model.Count game@(Model.Count != 1 ? "s" : "") owned</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-20 bg-navy-deep border border-slate-800/50 rounded-2xl">
            <span class="text-5xl mb-4 block">📚</span>
            <h2 class="font-outfit text-xl font-bold text-white mb-2">Your library is empty</h2>
            <p class="text-sm text-brand/50 mb-6">Purchase games from the store to see them here!</p>
            <a href="/Store" class="bg-accent text-navy-deep font-bold text-sm px-8 py-3 rounded-lg hover:bg-accent-dark hover:text-white transition-all">Browse Store</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-6 gap-4">
            @foreach (var item in Model)
            {
                <a href="/Store/ProductDetails/@item.GameId" class="bg-navy-deep border border-slate-800/50 rounded-xl overflow-hidden group cursor-pointer transition hover:border-accent/25 hover:shadow-lg hover:-translate-y-1">
                    <div class="relative h-[180px] overflow-hidden">
                        <img src="@item.Game?.CoverImageUrl" alt="@item.Game?.Title" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
                        <div class="absolute inset-0 bg-navy/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                            <span class="text-xs text-accent font-semibold">View Details</span>
                        </div>
                    </div>
                    <div class="p-3">
                        <h3 class="text-xs font-semibold text-white truncate">@item.Game?.Title</h3>
                        <div class="flex items-center gap-1.5 mt-1">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                            <span class="text-[10px] text-green-400">Owned</span>
                        </div>
                        <span class="text-[10px] text-brand/30 mt-1 block">Purchased @item.PurchaseDate.ToString("MMM dd, yyyy")</span>
                    </div>
                </a>
            }
        </div>
    }
</div>
