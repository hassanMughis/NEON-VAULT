@model Neon_vault.Models.ChatUser
@{
    ViewData["Title"] = "Account Settings";
}

@section Styles {
<style>
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .settings-card { animation: fadeIn 0.35s ease both; }
    .settings-card:nth-child(2) { animation-delay: 0.06s; }
    .settings-card:nth-child(3) { animation-delay: 0.12s; }
    .settings-card:nth-child(4) { animation-delay: 0.18s; }
    .form-input {
        width: 100%; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
        border-radius: 12px; padding: 12px 16px; color: #fff; font-size: 0.875rem;
        outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    }
    .form-input:focus { border-color: rgba(221,183,255,0.5); box-shadow: 0 0 0 3px rgba(221,183,255,0.07); }
    .form-input::placeholder { color: rgba(207,194,214,0.3); }
    .avatar-ring { box-shadow: 0 0 0 3px rgba(221,183,255,0.15), 0 0 20px rgba(221,183,255,0.1); }
</style>
}

<div class="min-h-screen bg-[#07101F] py-10 px-6">
    <div class="mx-auto max-w-3xl">
        <!-- Page Header -->
        <div class="flex items-center justify-between mb-8 settings-card">
            <div>
                <p class="text-[11px] font-bold text-accent/70 uppercase tracking-[2px] mb-2">Account</p>
                <h1 class="font-sora text-2xl font-extrabold text-white">Settings</h1>
                <p class="mt-1.5 text-sm text-brand/50">Manage your profile and community identity.</p>
            </div>
            <a href="/Community" class="inline-flex items-center gap-2 text-xs font-semibold text-brand/40 hover:text-accent transition-colors">
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
                Community
            </a>
        </div>

        @if (TempData["Message"] != null)
        {
            <div class="flex items-center gap-3 mb-6 bg-accent/10 border border-accent/25 text-accent text-sm px-5 py-3.5 rounded-xl settings-card">
                <svg class="w-4 h-4 fill-current shrink-0" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                @TempData["Message"]
            </div>
        }

        <form method="post" asp-action="UpdateProfile" enctype="multipart/form-data" class="space-y-5">
            @Html.AntiForgeryToken()

            <!-- Avatar Section -->
            <div class="settings-card bg-navy border border-white/5 rounded-2xl p-6">
                <h2 class="text-[10px] font-bold text-brand/30 uppercase tracking-[2px] mb-5">Profile Picture</h2>
                <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
                    <div class="relative shrink-0">
                        <img src="@(string.IsNullOrWhiteSpace(Model.ProfileImageUrl) ? "/images/neon_avatar.png" : Model.ProfileImageUrl)"
                             alt="Profile"
                             id="avatar-preview"
                             class="w-20 h-20 rounded-2xl object-cover border border-white/10 avatar-ring" />
                        <label for="profileImage" class="absolute -bottom-2 -right-2 w-7 h-7 rounded-xl bg-accent flex items-center justify-center cursor-pointer shadow-[0_0_12px_rgba(221,183,255,0.4)] hover:bg-accent-dark transition-colors">
                            <svg class="w-3.5 h-3.5 fill-navy-deep" viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                        </label>
                        <input type="file" name="profileImage" accept="image/*" id="profileImage" class="hidden" />
                    </div>
                    <div class="flex-1 text-center sm:text-left">
                        <p class="text-sm font-semibold text-white mb-1">@Model.DisplayName</p>
                        <p class="text-xs text-brand/40 mb-3">@@@@Model.Username</p>
                        <label for="profileImage" class="inline-flex items-center gap-2 text-xs font-semibold bg-white/5 border border-white/10 text-brand/60 hover:text-white hover:border-white/20 px-4 py-2 rounded-xl cursor-pointer transition-all duration-150">
                            <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                            Change Photo
                        </label>
                        <p class="text-[11px] text-brand/30 mt-2">PNG, JPG, WEBP up to your browser limits</p>
                    </div>
                </div>
            </div>

            <!-- Basic Info -->
            <div class="settings-card bg-navy border border-white/5 rounded-2xl p-6">
                <h2 class="text-[10px] font-bold text-brand/30 uppercase tracking-[2px] mb-5">Basic Info</h2>
                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label class="block text-xs font-semibold text-brand/50 mb-2">Username</label>
                        <input asp-for="Username" class="form-input" placeholder="username" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-brand/50 mb-2">Display Name</label>
                        <input asp-for="DisplayName" class="form-input" placeholder="Your Display Name" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-brand/50 mb-2">Email</label>
                        <input asp-for="Email" type="email" class="form-input" placeholder="email@example.com" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-brand/50 mb-2">New Password</label>
                        <input name="PasswordHash" type="password" class="form-input" placeholder="Leave blank to keep current" />
                    </div>
                </div>
            </div>

            <!-- Bio -->
            <div class="settings-card bg-navy border border-white/5 rounded-2xl p-6">
                <h2 class="text-[10px] font-bold text-brand/30 uppercase tracking-[2px] mb-5">About You</h2>
                <textarea asp-for="Bio" rows="4" class="form-input resize-none" placeholder="Tell players a little about yourself..."></textarea>
                <p class="text-xs text-brand/30 mt-2">Your bio will be visible on your community profile.</p>
            </div>

            <!-- Save -->
            <div class="settings-card flex justify-end">
                <button type="submit" class="inline-flex items-center gap-2 bg-accent text-navy-deep font-bold text-sm px-6 py-3 rounded-xl hover:bg-accent-dark hover:text-white transition-all duration-150 shadow-[0_0_20px_rgba(221,183,255,0.2)] hover:shadow-[0_0_28px_rgba(221,183,255,0.3)]">
                    <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/></svg>
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('profileImage').addEventListener('change', function (e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (ev) {
                document.getElementById('avatar-preview').src = ev.target.result;
            };
            reader.readAsDataURL(file);
        }
    });
</script>
}
