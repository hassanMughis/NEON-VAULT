@model List<Neon_vault.Models.Channel>
@{
    ViewData["Title"] = "Community Hub";
    var currentUser = ViewBag.CurrentUser as Neon_vault.Models.ChatUser;
    var products = ViewBag.Products as List<Neon_vault.Models.Game>;
}

@section Styles {
    <style>
        .chat-scroll { scroll-behavior: smooth; }
        .chat-scroll::-webkit-scrollbar { width: 6px; }
        .chat-scroll::-webkit-scrollbar-track { background: transparent; }
        .chat-scroll::-webkit-scrollbar-thumb { background: rgba(221, 183, 255, 0.2); border-radius: 10px; }
        .chat-scroll::-webkit-scrollbar-thumb:hover { background: rgba(221, 183, 255, 0.4); }
    </style>
}

<div class="flex flex-col md:flex-row h-[calc(100vh-64px)] overflow-hidden bg-navy">
    <!-- Mobile Channel Selector (shown on small screens) -->
    <div class="md:hidden p-3 bg-navy-deep border-b border-slate-800/50 flex items-center gap-2 overflow-x-auto">
        @foreach (var ch in Model)
        {
            <button onclick="joinChannel('@ch.Id', '@ch.Name')" class="channel-btn shrink-0 bg-white/5 border border-slate-800/50 text-brand/70 text-xs font-semibold px-3 py-2 rounded-lg hover:bg-white/10 transition" data-id="@ch.Id">
                # @ch.Name
            </button>
        }
    </div>

    <!-- Left Column: Channels -->
    <aside class="w-64 bg-navy-deep border-r border-slate-800/50 flex-col py-6 shrink-0 hidden md:flex">
        <div class="px-5 mb-4">
            <h2 class="font-sora text-xl font-bold text-white mb-1">Community Hub</h2>
            <p class="text-xs text-brand/50">Connect with other gamers.</p>
        </div>
        <div class="px-3 mt-4 flex-1 overflow-y-auto chat-scroll">
            @foreach (var cat in Model.GroupBy(c => c.Category))
            {
                <div class="mb-4">
                    <h3 class="px-2 text-[10px] font-bold text-brand/40 uppercase tracking-[2px] mb-2">@cat.Key</h3>
                    @foreach (var ch in cat)
                    {
                        <button onclick="joinChannel('@ch.Id', '@ch.Name')" class="channel-btn w-full text-left flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-brand/70 hover:bg-white/5 transition-all mb-1" data-id="@ch.Id">
                            <span class="text-accent/50 text-lg leading-none">#</span> @ch.Name
                        </button>
                    }
                </div>
            }
        </div>

        <div class="p-4 border-t border-slate-800/50 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-navy-deep font-bold" style="background-color: @currentUser.AvatarColorHex">
                @currentUser.Username.Substring(0, 1).ToUpper()
            </div>
            <div class="flex flex-col">
                <span class="text-sm font-bold text-white truncate max-w-[120px]">@currentUser.Username</span>
                @if (currentUser.IsTemporaryGuest)
                {
                    <span class="text-[10px] text-accent">Guest User</span>
                }
            </div>
        </div>
    </aside>

    <!-- Center Column: Chat -->
    <main class="flex-1 flex flex-col bg-navy relative min-w-0">
        <div class="h-14 border-b border-slate-800/50 flex items-center px-4 md:px-6 shrink-0 bg-navy/80 backdrop-blur-md z-10">
            <div class="flex items-center gap-2">
                <span class="text-accent text-2xl font-light">#</span>
                <h2 id="current-channel-name" class="font-bold text-white text-base md:text-lg">Select a channel</h2>
            </div>
        </div>

        <div id="chat-messages" class="flex-1 overflow-y-auto p-4 md:p-6 flex flex-col gap-4 chat-scroll">
            <div class="text-center text-brand/40 text-sm mt-10">Welcome to the Neon Vault Community! Select a channel to start chatting.</div>
        </div>

        <div class="p-3 md:p-4 bg-navy-deep/80 backdrop-blur-md border-t border-slate-800/50 shrink-0">
            <form id="chat-form" class="relative max-w-4xl mx-auto flex items-end gap-2">
                <input type="hidden" id="active-channel-id" />

                <div class="relative group">
                    <button type="button" onclick="document.getElementById('product-dropdown').classList.toggle('hidden')" class="bg-white/5 border border-slate-800/50 text-brand/70 p-3 rounded-xl hover:bg-white/10 hover:text-white transition" title="Attach Product">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                    </button>
                    <!-- Product Dropdown -->
                    <div id="product-dropdown" class="hidden absolute bottom-full left-0 mb-2 w-64 bg-navy-deep border border-slate-800/50 rounded-xl shadow-2xl p-2 max-h-64 overflow-y-auto chat-scroll z-50">
                        <div class="text-[10px] font-bold text-brand/40 uppercase px-2 mb-2">Attach Store Item</div>
                        @foreach(var prod in products)
                        {
                            <button type="button" onclick="attachProduct('@prod.Id', '@prod.Title')" class="w-full text-left flex items-center gap-2 p-2 hover:bg-white/5 rounded-lg transition group/item">
                                <img src="@prod.CoverImageUrl" class="w-8 h-8 object-cover rounded" />
                                <div class="flex-1 min-w-0">
                                    <div class="text-xs text-white truncate">@prod.Title</div>
                                    <div class="text-[10px] text-accent">$@prod.Price</div>
                                </div>
                            </button>
                        }
                    </div>
                </div>

                <div class="flex-1 relative bg-white/5 border border-slate-800/50 rounded-xl flex items-center transition-colors focus-within:border-accent min-w-0">
                    <input type="file" id="file-upload" class="hidden" accept="image/*,.pdf,.zip" />
                    <button type="button" onclick="document.getElementById('file-upload').click()" class="pl-3 pr-1 text-brand/50 hover:text-accent transition shrink-0">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5a2.5 2.5 0 0 1 5 0v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5a2.5 2.5 0 0 0 5 0V5c0-3.31-2.69-6-6-6S3 1.69 3 5v11.5c0 3.87 3.13 7 7 7s7-3.13 7-7V6h-1.5z"/></svg>
                    </button>
                    <input type="text" id="message-input" autocomplete="off" placeholder="Message channel..." class="w-full bg-transparent border-none py-3 px-2 text-white text-sm outline-none placeholder:text-brand/40 min-w-0" disabled />
                    <div id="attached-product-pill" class="hidden items-center gap-1 bg-accent/20 text-accent text-xs px-2 py-1 rounded mx-2 shrink-0">
                        <span id="attached-product-name" class="truncate max-w-[80px]"></span>
                        <button type="button" onclick="removeProduct()" class="hover:text-white">&times;</button>
                        <input type="hidden" id="attached-product-id" />
                    </div>
                </div>

                <button type="submit" id="send-btn" class="bg-accent text-navy-deep p-3 rounded-xl hover:bg-accent-dark transition disabled:opacity-50 disabled:cursor-not-allowed shadow-[0_0_15px_rgba(221,183,255,0.2)] shrink-0" disabled>
                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
                </button>
            </form>
        </div>
    </main>

    <!-- Right Column: Users -->
    <aside class="w-56 bg-navy-deep border-l border-slate-800/50 py-6 px-4 shrink-0 hidden lg:flex flex-col">
        <h3 class="font-outfit text-xs font-bold text-brand/40 uppercase tracking-[2px] mb-4">Active Members</h3>
        <div id="active-users-list" class="flex flex-col gap-3">
            <div class="flex items-center gap-3 opacity-50">
                <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center text-xs font-bold">?</div>
                <span class="text-sm text-brand/50 italic">Join a channel</span>
            </div>
        </div>
    </aside>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const currentUserId = '@currentUser.Id';
        const sessionId = '@ViewBag.SessionId';
        let currentChannelId = null;
        let attachmentUrl = null;

        function renderMessage(msg) {
            const isMe = msg.userId === currentUserId;
            const align = isMe ? 'self-end' : 'self-start';
            const bgClass = isMe ? 'bg-accent text-navy-deep' : 'bg-navy-deep border border-slate-800/50 text-white';
            const time = new Date(msg.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

            let productHtml = '';
            if (msg.product) {
                const p = typeof msg.product === 'string' ? JSON.parse(msg.product) : msg.product;
                const pid = p.Id || p.id;
                const ptitle = p.Title || p.title;
                const pimg = p.CoverImageUrl || p.coverImageUrl;
                const pprice = p.Price || p.price;
                productHtml = `
                    <a href="/Store/ProductDetails/${pid}" class="mt-2 block bg-navy border border-slate-700/50 rounded-lg p-2 hover:border-accent/50 transition max-w-[240px]">
                        <div class="flex gap-2">
                            <img src="${pimg}" class="w-12 h-12 object-cover rounded" />
                            <div class="flex-1 min-w-0">
                                <div class="text-xs font-bold text-white truncate">${ptitle}</div>
                                <div class="text-[10px] text-accent font-bold">$${pprice}</div>
                            </div>
                        </div>
                    </a>`;
            }

            let attachmentHtml = '';
            if (msg.attachmentUrl) {
                attachmentHtml = `<img src="${msg.attachmentUrl}" class="max-w-[240px] max-h-[200px] rounded-lg mt-2 object-cover border border-slate-700/50" />`;
            }

            const avatarHtml = !isMe ? `
                <div class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-navy-deep text-xs shrink-0" style="background-color: ${msg.avatarColor}">
                    ${msg.username.substring(0, 1).toUpperCase()}
                </div>` : '';

            return `
                <div class="flex gap-3 max-w-[80%] ${align}">
                    ${avatarHtml}
                    <div class="flex flex-col ${isMe ? 'items-end' : 'items-start'}">
                        ${!isMe ? `<span class="text-[11px] text-brand/50 mb-1 ml-1">${msg.username}</span>` : ''}
                        <div class="${bgClass} px-4 py-2.5 rounded-2xl shadow-sm">
                            <p class="text-sm whitespace-pre-wrap break-words">${msg.body}</p>
                            ${productHtml}
                            ${attachmentHtml}
                        </div>
                        <span class="text-[10px] text-brand/40 mt-1">${time}</span>
                    </div>
                </div>
            `;
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveMessage", function (msg) {
            const chatMessages = document.getElementById("chat-messages");
            chatMessages.insertAdjacentHTML('beforeend', renderMessage(msg));
            chatMessages.scrollTop = chatMessages.scrollHeight;
        });

        connection.start().catch(err => console.error(err.toString()));

        window.joinChannel = async function(id, name) {
            currentChannelId = id;
            document.getElementById('current-channel-name').textContent = name;
            document.getElementById('active-channel-id').value = id;
            document.getElementById('message-input').disabled = false;
            document.getElementById('send-btn').disabled = false;

            // Highlight active channel
            document.querySelectorAll('.channel-btn').forEach(b => {
                b.classList.remove('bg-white/10', 'text-white', 'border-l-2', 'border-accent');
                if(b.dataset.id === id) {
                    b.classList.add('bg-white/10', 'text-white', 'border-l-2', 'border-accent');
                }
            });

            // Load saved messages from server
            const chatMessages = document.getElementById("chat-messages");
            chatMessages.innerHTML = '<div class="text-center text-brand/40 text-xs mt-4">Loading messages...</div>';

            try {
                const response = await fetch(`/Community/GetMessages?channelId=${id}`);
                const messages = await response.json();
                chatMessages.innerHTML = '';
                if (messages.length === 0) {
                    chatMessages.innerHTML = '<div class="text-center text-brand/40 text-xs mt-4">No messages yet. Be the first to say something!</div>';
                } else {
                    messages.forEach(msg => {
                        chatMessages.insertAdjacentHTML('beforeend', renderMessage(msg));
                    });
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }
            } catch (err) {
                chatMessages.innerHTML = '<div class="text-center text-red-400 text-xs mt-4">Failed to load messages.</div>';
            }

            // Join the SignalR group for live updates
            connection.invoke("JoinChannel", id, sessionId).catch(err => console.error(err));
        };

        window.attachProduct = function(id, name) {
            document.getElementById('attached-product-id').value = id;
            document.getElementById('attached-product-name').textContent = name;
            document.getElementById('attached-product-pill').classList.replace('hidden', 'flex');
            document.getElementById('product-dropdown').classList.add('hidden');
        };

        window.removeProduct = function() {
            document.getElementById('attached-product-id').value = '';
            document.getElementById('attached-product-pill').classList.replace('flex', 'hidden');
        };

        // Handle File Upload
        document.getElementById('file-upload').addEventListener('change', async function(e) {
            if(!e.target.files.length) return;
            const file = e.target.files[0];
            if(file.size > 5 * 1024 * 1024) {
                alert('File too large. Maximum size is 5MB.');
                return;
            }

            const formData = new FormData();
            formData.append('file', file);

            document.getElementById('message-input').placeholder = "Uploading...";
            document.getElementById('message-input').disabled = true;

            try {
                const response = await fetch('/Community/UploadAttachment', { method: 'POST', body: formData });
                const data = await response.json();
                attachmentUrl = data.url;
                document.getElementById('message-input').placeholder = "File attached. Add a message...";
            } catch(e) {
                alert('Upload failed.');
                document.getElementById('message-input').placeholder = "Message channel...";
            }
            document.getElementById('message-input').disabled = false;
        });

        // Handle Form Submit
        document.getElementById('chat-form').addEventListener('submit', function (e) {
            e.preventDefault();
            const input = document.getElementById('message-input');
            const msg = input.value.trim();
            const prodId = document.getElementById('attached-product-id').value;

            if (!msg && !attachmentUrl && !prodId) return;

            connection.invoke("SendMessage", currentChannelId, sessionId, msg, attachmentUrl, prodId)
                .then(() => {
                    input.value = '';
                    attachmentUrl = null;
                    input.placeholder = "Message channel...";
                    document.getElementById('file-upload').value = '';
                    removeProduct();
                })
                .catch(err => console.error(err));
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            if(!e.target.closest('.group')) {
                document.getElementById('product-dropdown').classList.add('hidden');
            }
        });
    </script>
}
